# Core
COMPOSE_PROJECT_NAME=homelab
TZ=UTC
PUID=1000
PGID=1000
DATA_DIR=./data
DOMAIN=example.ts.net
TS_CERT_EMAIL=admin@example.com
TRAEFIK_LOG_LEVEL=INFO

# Traefik
TRAEFIK_DASHBOARD_HOST=traefik.example.ts.net
TRAEFIK_AUTH_MIDDLEWARE=authentik@docker

# Authentik
AUTHENTIK_HOST=auth.example.ts.net
AUTHENTIK_SECRET_KEY=change_me
AUTHENTIK_POSTGRES_PASSWORD=change_me
AUTHENTIK_REDIS_PASSWORD=change_me
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change_me
AUTHENTIK_BOOTSTRAP_TOKEN=change_me

# Nextcloud
NEXTCLOUD_HOST=nextcloud.example.ts.net
NEXTCLOUD_DB_PASSWORD=change_me
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me

# Jellyfin
JELLYFIN_HOST=jellyfin.example.ts.net

# Jellyseerr
JELLYSEERR_HOST=jellyseerr.example.ts.net

# Homepage
HOMEPAGE_HOST=home.example.ts.net

# Dozzle logs
DOZZLE_HOST=logs.example.ts.net
